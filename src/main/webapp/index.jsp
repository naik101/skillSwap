<%@ page language="java" contentType="text/html; charset=UTF-8" pageEncoding="UTF-8"%>
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Welcome | Skill Swap</title>
    <link rel="stylesheet" href="css/styles.css">
</head>
<body>
    <nav class="navbar">
        <a href="index.jsp" class="nav-brand">✨ <span>SkillSwap</span></a>
        <div class="nav-links">
            <a href="login.jsp" class="nav-link">Log In</a>
            <a href="register.jsp" class="btn">Get Started</a>
        </div>
    </nav>

    <div class="container">
        <div class="hero">
            <h1>Master New Skills Together</h1>
            <p style="font-size: 1.2rem; max-width: 600px; margin: 0 auto 2rem auto;">
                Join an exclusive community of students. Trade your expertise for the knowledge you want. No money involved, just pure learning.
            </p>
            <a href="register.jsp" class="btn" style="width: auto; padding: 1rem 2.5rem; font-size: 1.1rem;">Join the Community</a>
        </div>

        <div class="grid-container">
            <div class="card" style="text-align: center;">
                <div style="font-size: 3rem; margin-bottom: 1rem;">🎓</div>
                <h3>Offer Your Skills</h3>
                <p>Are you great at Math, Java, or Design? Offer your skills to others who need help.</p>
            </div>
            <div class="card" style="text-align: center;">
                <div style="font-size: 3rem; margin-bottom: 1rem;">🔍</div>
                <h3>Find Your Match</h3>
                <p>Our algorithm matches you with students who want what you offer, and offer what you want.</p>
            </div>
            <div class="card" style="text-align: center;">
                <div style="font-size: 3rem; margin-bottom: 1rem;">🚀</div>
                <h3>Learn & Grow</h3>
                <p>Connect, collaborate, and master new subjects without spending a dime.</p>
            </div>
        </div>
    </div>
